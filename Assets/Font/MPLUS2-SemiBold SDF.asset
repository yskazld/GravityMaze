    characterSetSelectionMode: 8
    characterSequence: "\n !&'(),-./0123456789:=>?ABCDEFGHIJKLMNOPRSTUVWYZ[]_abcdefghijklmnopqrstuvwxyz{|}\u2026\u3000\u3001\u3002\n
      \u300C\u300D\u3042\u3044\u3046\u3048\u304A\u304B\u304C\u304D\u304E\u304F\u3051\u3053\u3055\u3057\u3058\u3059\u305A\u305B\u305D\u305F\u3060\u3063\u3064\u3066\u3067\u3068\u3069\u306A\u306B\u306D\u306E\u306F\u3070\u3072\u3073\u3078\u3079\u307B\u307E\u307F\u3080\u3081\u3082\u3084\u3088\u3089\u308A\u308B\u308C\u308D\u308F\u3092\u3093\n
      \u30A2\u30A3\u30A4\u30AF\u30B0\u30B5\u30B7\u30BA\u30BF\u30C0\u30C3\u30C6\u30C8\u30C9\u30CA\u30CD\u30D0\u30D1\u30D2\u30D5\u30D6\u30D7\u30DC\u30E0\u30E9\u30EA\u30EB\u30ED\u30F3\u30FC\n
      \u4E2D\u4E86\u4ECA\u4ED5\u4EE3\u4EF6\u4F55\u5024\u5165\u5197\u51FA\u5229\u5272\u52A0\u52D5\u5370\u53D6\u5404\u5408\u5546\u56F2\u5728\u5831\u5834\u5897\u5909\u5916\u591C\u5927\u5931\u5B57\u5B58\u5B8C\u5B9A\u5BA4\u5BFE\u5C11\n
      \u5C4B\u5E30\u5E97\u5EF6\u5F53\u5F97\u60C5\u6163\u623B\u6240\u6249\u629E\u62BC\u62E1\u63DB\u6557\u6570\u6587\u65B9\u65E5\u660E\u666E\u666F\u672C\u6761\u6765\u677F\u6C17\u6C60\u6E1B\u6FC3\u7269\u7528\u753B\u767B\u770B\u77E2\u79FB\u7AEF\u7D76\u7F6E\n
      \u8131\u8272\u8857\u8868\u8907\u898B\u89E3\u8A00\u8A2D\u8A66\u8AAD\u8ABF\u8AC7\u8B0E\u8C61\u8CB7\u8D77\u8FBC\u901A\u9032\u9045\u9053\u9055\u9060\u9078\u90E8\u914D\u91CD\u9332\u958B\u96F0\u96FB\u9727\u9762\u97F3\u983C\u9CF4\uFEFF\uFF01\uFF1A\uFF1F\n
      \u9262\u5408\u8A08\n \u59CB\u3081\u304B\u3089\u3001\u7D9A\u304D\u304B\u3089\u3001\u4ED6\n
      \u958B\u767A\u8005\u306E\u4ED6\u306E\u30B2\u30FC\u30E0\n \u3069\u3053\u304B\u306B\u9375\u304C\u73FE\u308C\u305F\uFF01\uFF01\n\n
      \u3082\u3046\u4E00\u5EA6\n \u901A\u4FE1\u72B6\u6CC1\u304C\u60AA\u3044\u307F\u305F\u3044\u3067\u3059\u3002\u901A\u4FE1\u74B0\u5883\u306E\u826F\u3044\u3068\u3053\u308D\u3067\u3001\u3082\u3046\u4E00\u5EA6\u30C8\u30E9\u30A4\u3057\u3066\u307F\u3066\u304F\u3060\u3055\u3044\n\n
      \u8A00\u8A9E\u5207\u66FF\n\n\n\"\u304A\u304B\u3042\u3055\u3093\u306B\u983C\u307E\u308C\u3066\u3001\u5546\u5E97\u8857\u3078\u8CB7\u3044\u7269\u306B\u6765\u305F\u3002\",\n\"\u3044\u3064\u3082\u901A\u308A\u306E\u3001\u898B\u6163\u308C\u305F\u666F\u8272\u306E\u306F\u305A\u3060\u3063\u305F\u3051\u3069\u3001\u306A\u306B\u304B\u5909\u3060\uFF01\",\n\"\u3044\u3084\u3001\u6C17\u306B\u3057\u3066\u3082\u4ED5\u65B9\u304C\u306A\u3044\uFF01\u4ECA\u65E5\u306F\u65E5\u672C\u4EE3\u8868\u306E\u8A66\u5408\u304C\u3042\u308B\u3093\u3060\u3002\u591C\u307E\u3067\u306B\u306F\u3001\u7D76\u5BFE\u5E30\u3089\u306A\u3044\u3068\uFF01\"\n\"\u2026\u2026\u3042\u308C\uFF1F\u306A\u3093\u3060\u304B\u3001\u9727\u304C\u51FA\u3066\u304D\u305F\uFF1F\");\n\"\u2026\u2026\u3053\u3053\u306F\u2026\u2026\uFF1F\u3055\u3063\u304D\u307E\u3067\u3068\u3001\u96F0\u56F2\u6C17\u304C\u9055\u3046\u2026\u2026\");\n\"\u9727\u304C\u6FC3\u304F\u3066\u3001\u9060\u304F\u304C\u3088\u304F\u898B\u3048\u306A\u3044\u2026\u2026\");\n\"\u2026\u2026\u3053\u3093\u306A\u770B\u677F\u3001\u3042\u3063\u305F\u3063\u3051\uFF1F\");\n\"\u770B\u677F\u306E\u6587\u5B57\uFF1A\",\n\"\u300C\u8131\u51FA\u3057\u305F\u3051\u308C\u3070\u3001\u5404\u5E97\u306E\u8B0E\u3092\u89E3\u3044\u3066\u307F\u308D\uFF01\uFF01\u300D\"\n\"\u8131\u51FA\u2026\u2026\uFF1F\u5197\u8AC7\u3001\u3060\u3088\u306D\u2026\u2026\uFF1F\",
      2f);\n\"\u2026\u2026\u3067\u3082\u3001\u623B\u308A\u9053\u304C\u898B\u3048\u306A\u3044\u3002\u4ED5\u65B9\u306A\u3044\u3001\u9032\u3080\u3057\u304B\u306A\u3055\u305D\u3046\u3060\u3002\");\n\"\u672C\u5C4B\u3060\u3051\u3001\u6249\u304C\u958B\u3044\u3066\u308B\u2026\u2026\u3068\u308A\u3042\u3048\u305A\u3001\u5165\u3063\u3066\u307F\u3088\u3046\u3002\");\n\"\u2026\u2026\u4E2D\u306F\u666E\u901A\u306E\u672C\u5C4B\u307F\u305F\u3044\u3060\u3002\");\n\"\u753B\u9762\u306E\u7AEF\u306B\u77E2\u5370\u304C\u3042\u308B\u306A\u3002\u62BC\u3059\u3068\u3001\u90E8\u5C4B\u3092\u79FB\u52D5\u3067\u304D\u305D\u3046\u3060\u3002\");\n\"\u306A\u308B\u307B\u3069\u3001\u5834\u6240\u304C\u5909\u308F\u3063\u305F\u3002\",
      2f);\n\"\u6C17\u306B\u306A\u308B\u3068\u3053\u308D\u3092\u30BF\u30C3\u30D7\u3059\u308B\u3068\u3001\u62E1\u5927\u3067\u304D\u308B\u307F\u305F\u3044\u3060\u3002\");\n\"\u3053\u308C\u3067\u3058\u3063\u304F\u308A\u8ABF\u3079\u3089\u308C\u308B\u306A\uFF01\");\n\"\u30DC\u30BF\u30F3\u304C\u3042\u308B\u2026\u2026\u62BC\u3057\u305F\u3089\u3001\u4F55\u304B\u8D77\u3053\u308B\u304B\u3082\uFF1F\");\n\"\u3088\u3057\u3001\u6249\u304C\u958B\u3044\u305F\uFF01\u5C11\u3057\u305A\u3064\u9032\u3081\u3070\u3001\u5916\u306B\u51FA\u3089\u308C\u308B\u304B\u3082\u3057\u308C\u306A\u3044\u3002\",\n\"\u4ECA\u65E5\u306F\u65E5\u672C\u4EE3\u8868\u306E\u8A66\u5408\u304C\u3042\u308B\u3093\u3060\u3002\u591C\u307E\u3067\u306B\u306F\u3001\u7D76\u5BFE\u5E30\u3089\u306A\u3044\u3068\uFF01\"\n\u3088\u3057\u623B\u3063\u3066\u304D\u305F\uFF01\uFF01\\n\u3053\u308C\u304B\u3089\u307E\u305F\u8B0E\u89E3\u304D\u958B\u59CB\u3060\uFF01\\n\u65E9\u304F\u5BB6\u306B\u5E30\u3089\u306A\u3044\u3068\uFF01\uFF01\n\n\u201D\u3069\u3046\u3084\u3089\u3001\u3044\u305F\u308B\u3068\u3053\u308D\u306B\u30A2\u30A4\u30C6\u30E0\u304C\u3042\u308B\u3089\u3057\u3044\uFF01\u201D\n\u201D\u30A2\u30A4\u30C6\u30E0\u3092\u4F7F\u3046\u6642\u306F\u3001\u753B\u9762\u3057\u305F\u306E\u30A2\u30A4\u30C6\u30E0\u753B\u50CF\u3092\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u67A0\u304C\u8D64\u304F\u306A\u3063\u305F\u3089\u3001\u4F7F\u3044\u305F\u3044\u5834\u6240\u3092\u30AF\u30EA\u30C3\u30AF\u3059\u308B\u3068\u4F7F\u3048\u305D\u3046\u3060\uFF01\u201D\n\u201D\u3053\u306E\u9375\u3092\u3069\u3053\u304B\u3067\u4F7F\u3048\u3070\u3044\u3044\u306E\u304B\u306A\uFF1F\u201D\n\n\u2026\u2026\u3053\u308C\u3067\u6700\u5F8C\u306E\u306F\u305A\uFF01\n\"\u3084\u3063\u3068\u2026\u2026\u51FA\u3089\u308C\u305F\uFF01\uFF01\"\n\u6642\u8A08\u3092\u898B\u3066\u2026\u2026\u307E\u306017:30\u3060\uFF01\n\u4ECA\u304B\u3089\u5E30\u308C\u3070\u3001\u30B5\u30C3\u30AB\u30FC\u306E\u8A66\u5408\u9593\u306B\u5408\u3046\uFF01\uFF01\n\u9727\u306A\u3093\u3066\u3001\u3082\u3046\u3053\u308A\u3054\u308A\u3060\u2026\u2026\uFF01\n\u65E5\u672C\u4EE3\u8868\u6226\u3001\u9593\u306B\u5408\u3046\uFF01\u4ECA\u65E5\u306F\u52DD\u3064\u305E\uFF01\uFF01\n\u5E30\u3063\u305F\u3089\u3001\u304A\u304B\u3042\u3055\u3093\u306B\u3082\u4E0D\u601D\u8B70\u306A\u4F53\u9A13\u3092\u8AAC\u660E\u3057\u306A\u3044\u3068\u2026\u2026\uFF01\n\n\u5E83\u544A\u3092\u898B\u308B\u3068\u30D2\u30F3\u30C8\u307E\u305F\u306F\u7B54\u3048\u304C\u304C\u307F\u308C\u307E\u3059\n\n\n\u672C\u68DA\u304C\u602A\u3057\u3044|The
      bookshelf is suspicious\t\u30B9\u30A4\u30C3\u30C1\u306E\u8272\u3092\u672C\u306E\u8272\u3068\u540C\u3058\u9806\u756A\u3067\u4E26\u3079\u3066\u307F\u3088\u3046\uFF01|Match
      the switch colors to the book colors in the same order!\n\u82B1\u306E\u6570\u5B57\u304C\u602A\u3057\u3044|The
      numbers on the flowers look suspicious\t\u5404\u82B1\u306B\u66F8\u3044\u3066\u3042\u308B\u6570\u5B57\u306E\u9806\u756A\u306B\u30B9\u30A4\u30C3\u30C1\u3092\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Press
      the switches in the order of the numbers on the flowers!\n\u6570\u5B57\u304C\u602A\u3057\u3044|The
      numbers look suspicious\t5\u3064\u306E\u5024\u672D\u306E\u5408\u8A08\u91D1\u984D\u3092\u6C42\u3081\u3066\u3001\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Add
      up the five price tags and enter the total!\n\u30B3\u30C3\u30D7\u306E\u4E2D\u8EAB\u304C\u602A\u3057\u3044|The
      contents of the cups look suspicious\t\u30B3\u30C3\u30D7\u306E\u6DB2\u91CF\u3092\u5408\u308F\u305B\u3066\u307F\u3088\u3046\uFF01|Match
      the amount of liquid in the cups!\n\u9375\u304C\u602A\u3057\u3044|The key looks
      suspicious\t\u6249\u306E\u3068\u3053\u308D\u3067\u9375\u3092\u4F7F\u3063\u3066\u307F\u3088\u3046\uFF01|Try
      using the key by the door!\n\u7BB1\u306E\u4E2D\u304C\u602A\u3057\u3044|The
      inside of the box looks suspicious\t9\u3064\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u7BB1\u306E\u4E2D\u306E\u8272\u3068\u5408\u308F\u305B\u3066\u307F\u3088\u3046\uFF01|Match
      the nine switches to the colors inside the box!\n\u8A18\u53F7\u306E\u4E26\u3073\u304C\u602A\u3057\u3044|The
      order of the symbols looks suspicious\t\u8A18\u53F7\u306E\u4E26\u3073\u306B\u5408\u308F\u305B\u3066\u3001\u90E8\u5C4B\u306E\u9685\u3005\u306B\u3042\u308B\u30A2\u30EB\u30D5\u30A1\u30D9\u30C3\u30C8\u3092\u4E26\u3079\u3066\u307F\u3088\u3046\uFF01|Arrange
      the letters around the room to match the order of the symbols!\n\u91CE\u83DC\u306E\u4E26\u3073\u304C\u602A\u3057\u3044|The
      order of the vegetables looks suspicious\t\u91CE\u83DC\u306E\u4E26\u3073\u306B\u5408\u308F\u305B\u3066\u30B9\u30A4\u30C3\u30C1\u3092\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Press
      the switches to match the order of the vegetables!\n\u91CE\u83DC\u306E\u6570\u304C\u602A\u3057\u3044|The
      number of vegetables looks suspicious\t\u91CE\u83DC\u306E\u6570\u306B\u5408\u308F\u305B\u3066\u3001\u30B5\u30A4\u30B3\u30ED\u306E\u76EE\u3092\u5909\u3048\u3066\u307F\u3088\u3046\uFF01|Change
      the dice faces to match the number of vegetables!\n\u30B9\u30FC\u30D1\u30FC\u30DE\u30F3\u306E\u5149\u308B\u624B\u888B\u304C\u602A\u3057\u3044|Superman's
      glowing gloves look suspicious\t\u5149\u308B\u624B\u888B\u306B\u5408\u308F\u305B\u3066\u3001\u30AF\u30DE\u306E\u4EBA\u5F62\u306E\u76EE\u306E\u3001\u8D64\u3068\u7DD1\u306E\u30DC\u30BF\u30F3\u3092\u9806\u756A\u306B\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Following
      the glowing gloves press the red and green buttons on the bear doll's eyes
      in order!\n\u96FB\u8ECA\u306E\u30BF\u30A4\u30E4\u306E\u30B5\u30A4\u30BA\u304C\u602A\u3057\u3044|The
      train wheel sizes look suspicious\t\u96FB\u8ECA\u306E\u30BF\u30A4\u30E4\u306E\u30B5\u30A4\u30BA\u306B\u5408\u308F\u305B\u3066\u3001\u304A\u57CE\u306E\u524D\u306E\u30DC\u30BF\u30F3\u3092\u64CD\u4F5C\u3057\u3066\u307F\u3088\u3046\uFF01|Operate
      the buttons in front of the castle to match the train wheel sizes!\n\u51FA\u53E3\u306E\u6249\u8FD1\u304F\u306E\u30ED\u30DC\u30C3\u30C8\u304C\u602A\u3057\u3044|The
      robot near the exit door looks suspicious\t\u30ED\u30DC\u30C3\u30C8\u306B\u624B\u306B\u5165\u308C\u305F\u4EBA\u5F62\u306E\u76EE\u3092\u306F\u3081\u8FBC\u3093\u3067\u307F\u3088\u3046\uFF01|Try
      fitting the doll eyes you found into the robot!\n\u30AA\u30EC\u30F3\u30B8\u8272\u306E\u30DD\u30B9\u30BF\u30FC\u3068\u30AF\u30DE\u306E\u4EBA\u5F62\u304C\u602A\u3057\u3044|The
      orange poster and the bear doll look suspicious\tUFO\u30AD\u30E3\u30C3\u30C1\u30E3\u30FC\u306B\u3044\u308B\u30AF\u30DE\u306E\u4EBA\u5F62\u306E\u8272\u306B\u5408\u308F\u305B\u3066\u3001\u30DC\u30BF\u30F3\u306E\u8272\u3092\u5909\u3048\u3066\u307F\u3088\u3046\uFF01|Change
      the button colors to match the colors of the bear dolls in the claw machine!\n\u30AC\u30C1\u30E3\u30AC\u30C1\u30E3\u304C\u602A\u3057\u3044|The
      capsule machine looks suspicious\t\u30B3\u30A4\u30F3\u6392\u51FA\u53E3\u3092\u63A2\u3057\u3066\u3001\u30AC\u30C1\u30E3\u30AC\u30C1\u30E3\u306B\u30B3\u30A4\u30F3\u3092\u5165\u308C\u3066\u307F\u3088\u3046\uFF01|Find
      the coin return slot and put a coin into the capsule machine!\n\u9752\u3044\u30DD\u30B9\u30BF\u30FC\u304C\u602A\u3057\u3044|The
      blue poster looks suspicious\t\u9752\u3044\u30DD\u30B9\u30BF\u30FC\u306B\u63CF\u304B\u308C\u305F\u30B3\u30DE\u30F3\u30C9\u3092\u5165\u529B\u3057\u3066\u307F\u3088\u3046|Try
      entering the command shown on the blue poster!\n\u68DA\u306B\u98FE\u3089\u308C\u3066\u3044\u308B\u9774\u304C\u602A\u3057\u3044|The
      shoes displayed on the shelf look suspicious\t\u68DA\u306B\u3042\u308B\uFF16\u3064\u306E\u9774\u306B\u66F8\u3044\u3066\u3042\u308B\u6570\u5B57\u3092\u5143\u306B\u3001\u7BB1\u306E\u30DC\u30BF\u30F3\u306E\u6570\u5B57\u3092\u5909\u3048\u3066\u307F\u3088\u3046\uFF01|Use
      the numbers written on the six shoes on the shelf to change the numbers on
      the box buttons!\n\u5F15\u304D\u51FA\u3057\u306E\u30C9\u30A2\u30CE\u30D6\u304C\u602A\u3057\u3044|The
      drawer knob looks suspicious\t\u624B\u306B\u5165\u308C\u305F\u30C9\u30A2\u30CE\u30D6\u3092\u4F7F\u3063\u3066\u307F\u3088\u3046\uFF01|Try
      using the knob you found!\n\u30D6\u30FC\u30C4\u306E\u5199\u771F\u304C\u602A\u3057\u3044|The
      boot photo looks suspicious\t\u30AB\u30E9\u30FC\u30DC\u30C3\u30AF\u30B9\u306E\u4E0B\u6BB5\u306E\u7BB1\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Try
      pressing the switches on the box in the bottom section of the cubby shelf!\n\u9375\u304C\u602A\u3057\u3044|The
      key looks suspicious\t\u30C9\u30A2\u306E\u30ED\u30C3\u30AF\u3092\u9375\u3067\u958B\u3051\u3066\u307F\u3088\u3046\uFF01|Try
      unlocking the door with the key!\n\u30CF\u30F3\u30AC\u30FC\u306B\u639B\u304B\u3063\u3066\u3044\u308B\u6D0B\u670D\u304C\u602A\u3057\u3044|The
      clothes hanging on the hanger look suspicious\t\u304B\u304B\u3063\u3066\u3044\u308B\u6D0B\u670D\u3092\u30D2\u30F3\u30C8\u306B\u30BF\u30F3\u30B9\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u62BC\u3057\u3066\u307F\u3088\u3046|Use
      the hanging clothes as a clue and press the dresser switches!\n\u30BF\u30AA\u30EB\u306B\u63CF\u304B\u308C\u305F\u540D\u524D\u304C\u602A\u3057\u3044|The
      names written on the towels look suspicious\t\u30BF\u30AA\u30EB\u306B\u63CF\u304B\u308C\u305F\uFF16\u4EBA\u306E\u540D\u524D\u306E\u982D\u6587\u5B57\u3092\u3001\u30AB\u30FC\u30C6\u30F3\u306B\u639B\u304B\u3063\u3066\u3044\u308B\u30DC\u30FC\u30C9\u306B\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Enter
      the initials of the six names written on the towels onto the board hanging
      by the curtain!\n\u30AB\u30FC\u30C6\u30F3\u306E\u4E2D\u306B\u639B\u304B\u3063\u3066\u3044\u308BT\u30B7\u30E3\u30C4\u304C\u602A\u3057\u3044|The
      T-shirts hanging behind the curtain look suspicious\tT\u30B7\u30E3\u30C4\u306E\u8272\u306E\u9806\u756A\u306B\u3001\u93E1\u306E\u53F3\u4E0A\u306E\u30B9\u30A4\u30C3\u30C1\u306E\u8272\u3092\u5909\u3048\u3066\u307F\u3088\u3046\uFF01|Change
      the colors of the switches at the upper right of the mirror to match the order
      of the T-shirt colors!\n\u93E1\u306B\u63CF\u304B\u308C\u3066\u3044\u308B\u6570\u5B57\u304C\u602A\u3057\u3044|The
      numbers on the mirror look suspicious\t\u51FA\u53E3\u306E\u6249\u306E\u30B3\u30FC\u30C9\u3092\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Try
      entering the code for the exit door!\n\u7070\u8272\u306E\u6642\u8A08\u304C\u602A\u3057\u3044|The
      gray clock looks suspicious\t\u91D1\u5EAB\u306E\u30C0\u30A4\u30E4\u30EB\u306E\u5411\u304D\u3092\u3001\u7070\u8272\u306E\u6642\u8A08\u306E\u77ED\u91DD\u3001\u9577\u91DD\u3001\u79D2\u91DD\u306E\u4F4D\u7F6E\u306B\u5408\u308F\u305B\u3066\u307F\u3088\u3046\uFF01|Match
      the directions of the safe dials to the positions of the hour hand minute hand
      and second hand on the gray clock!\n4\u3064\u4E26\u3093\u3067\u308B\u6642\u8A08\u304C\u602A\u3057\u3044|The
      four clocks in a row look suspicious\t\u5C55\u793A\u3055\u308C\u3066\u3044\u308B\u6642\u8A08\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u6642\u8A08\u306E\u91DD\u306E\u5411\u304D\u3092\u30D2\u30F3\u30C8\u306B\u4E26\u3079\u3066\u307F\u3088\u3046\uFF01|Arrange
      the switches on the displayed clocks using the directions of the clock hands
      as a clue!\n\u6642\u8A08\u306E\u30DD\u30B9\u30BF\u30FC\u306E\u6587\u5B57\u304C\u602A\u3057\u3044|The
      letters on the clock poster look suspicious\t\u300CLOGE\u300D\u3092\u4E0A\u4E0B\u53CD\u5BFE\u306B\u3059\u308B\u3068\u3001\u6D6E\u304B\u3073\u4E0A\u304C\u308B\u6570\u5B57\u3092\u68DA\u306E\u30B3\u30FC\u30C9\u306B\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Turn
      \"LOGE\" upside down and enter the number that appears as the shelf code!\n\u96FB\u6C60\u304C\u602A\u3057\u3044|The
      battery looks suspicious\t\u96FB\u6C60\u3092\u51FA\u53E3\u306E\u6249\u306B\u306F\u3081\u3066\u307F\u3088\u3046\uFF01|Try
      inserting the battery into the exit door!\n\u30D6\u30E9\u30F3\u30B3\u3068\u6ED1\u308A\u53F0\u304C\u602A\u3057\u3044|The
      swing and slide look suspicious\t\u30D6\u30E9\u30F3\u30B3\u306B\u793A\u3055\u308C\u305F\u6570\u5B57\u306E\u9806\u756A\u306B\u3001\u6ED1\u308A\u53F0\u306E\u56DB\u89D2\u3092\u305F\u3069\u3063\u305F\u6642\u306E\u77E2\u5370\u3092\u96FB\u706F\u306B\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Follow
      the numbers shown on the swing and enter into the lamp the arrows you get by
      tracing the squares on the slide!\n\u5674\u6C34\u304C\u602A\u3057\u3044|The
      fountain looks suspicious\t\u5674\u6C34\u306E\u6C34\u306E\u52E2\u3044\u3092\u30D2\u30F3\u30C8\u306B\u3057\u3066\u3001\u30D9\u30F3\u30C1\u306E\u4E0B\u306E\u5B9D\u7BB1\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Use
      the force of the fountain water as a clue and press the switches on the treasure
      chest under the bench!\n\u5B9D\u7BB1\u306E\u30E1\u30E2\u304C\u602A\u3057\u3044|The
      note in the treasure chest looks suspicious\t\u516C\u5712\u3092\u82F1\u8A9E\u3067\u306FPARK\u3068\u3044\u3046\u3088\u306D\uFF01\u866B\u304B\u3054\u306B\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|A
      park is called \"PARK\" in English right? Try entering it into the insect cage!\n\u306F\u3055\u307F\u304C\u602A\u3057\u3044|The
      scissors look suspicious\t\u306F\u3055\u307F\u3092\u4F7F\u3063\u3066\u3001\u516C\u5712\u306E\u51FA\u53E3\u306E\u5B89\u5168\u30C6\u30FC\u30D7\u3092\u30AB\u30C3\u30C8\u3057\u3066\u307F\u3088\u3046\uFF01|Use
      the scissors to cut the safety tape at the park exit!\n\u30C8\u30E9\u30F3\u30D7\u306E\u30DE\u30FC\u30AF\u304C\u602A\u3057\u3044|The
      playing card suits look suspicious\t\u8272\u306B\u5408\u308F\u305B\u3066\u3001\u30C8\u30E9\u30F3\u30D7\u306E\u30DE\u30FC\u30AF\u3092\u5408\u308F\u305B\u3066\u307F\u3088\u3046\uFF01|Match
      the playing card suits to the colors!\n\u4EBA\u5F62\u306E\u76EE\u306E\u52D5\u304D\u304C\u602A\u3057\u3044|The
      movement of the doll's eyes looks suspicious\t\u5C0F\u7BB1\u306E\u30D4\u30F3\u30AF\u3068\u9752\u306E\u30DC\u30BF\u30F3\u3092\u3001\u4EBA\u5F62\u306E\u76EE\u304C\u5149\u308B\u9806\u756A\u306B\u62BC\u3057\u3066\u307F\u3088\u3046\uFF01|Press
      the pink and blue buttons on the small box in the order the doll's eyes light
      up!\n\u7A93\u306E\u3064\u305F\u306E\u9577\u3055\u304C\u602A\u3057\u3044|The
      lengths of the vines on the window look suspicious\t\u90E8\u5C4B\u306E\u9685\u306E\u30B9\u30A4\u30C3\u30C1\u3092\u3064\u305F\u306E\u9577\u3055\u306B\u5408\u308F\u305B\u3066\u307F\u3088\u3046\uFF01|Match
      the switches in the corner of the room to the vine lengths!\n\u4ED8\u7B8B\u306B\u63CF\u304B\u308C\u3066\u3044\u308B\u540D\u524D\u304C\u602A\u3057\u3044|The
      names written on the sticky notes look suspicious\t\u30AA\u30EC\u30F3\u30B8\u8272\u306E\u7BB1\u306E\u30B9\u30A4\u30C3\u30C1\u306B\u3001\u540D\u524D\u306E\u982D\u6587\u5B57\u3092\u5165\u529B\u3057\u3066\u307F\u3088\u3046\uFF01|Enter
      the initials of the names into the switches on the orange box!\n\u30B8\u30B0\u30BD\u30FC\u30D1\u30BA\u30EB\u304C\u602A\u3057\u3044|The
      jigsaw puzzle looks suspicious\t\u6249\u306E\u53F3\u4E0A\u306E\u67A0\u306B\u3001\u5165\u624B\u3057\u305F\u30B8\u30B0\u30BD\u30FC\u30D1\u30BA\u30EB\u306F\u3081\u3066\u307F\u3088\u3046\uFF01|Try
      fitting the jigsaw puzzle piece you found into the frame at the upper right
      of the door!"
